{
  "schema_version": "1.0",
  "product_id": "vet",
  "product_name": "VetTasksAI",
  "official_domain": "vettasksai.com",
  "official_github_repo": "https://github.com/laudoluxDev/vettasksai-mcp",
  "official_package": "@tasksai/install",
  "installer": {
    "preferred": "npx",
    "npx": {
      "command": "npx",
      "args": [
        "@tasksai/install",
        "vet",
        "--source",
        "https://github.com/laudoluxDev/vettasksai-mcp"
      ],
      "requires": [
        "node",
        "npm",
        "npx"
      ]
    }
  },
  "supported_clients": [
    "claude_desktop",
    "cursor",
    "windsurf",
    "codex"
  ],
  "auth": {
    "method": "browser_device_flow",
    "connect_url": "https://vettasksai.com/connect",
    "fallback": "license_key"
  },
  "security": {
    "require_domain_verification": true,
    "require_repo_verification": true,
    "disallow_arbitrary_manifest_commands": true,
    "native_installer_user_approval_required": true
  },
  "health_check": {
    "command": "npx",
    "args": [
      "@tasksai/install",
      "vet",
      "doctor"
    ]
  },
  "uninstall": {
    "command": "npx",
    "args": [
      "@tasksai/install",
      "vet",
      "uninstall"
    ]
  },
  "support": {
    "url": "https://vettasksai.com/support",
    "email": "support@vettasksai.com"
  }
}
